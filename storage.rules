rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Any authenticated user can read/write their own logo folder.
    // Intentionally does NOT check email_verified or sign_in_provider
    // so that both Google OAuth and email/password accounts work identically.
    match /logos/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
