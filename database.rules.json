{
  "rules": {
    ".read": false,
    ".write": false,

    "deliveries": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid"
      }
    },

    "riders-list": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid"
      }
    },

    "businesses": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid",
        "profile": {
          ".read": true
        },
        "feedback": {
          "$deliveryId": {
            ".write": "!data.exists() && root.child('delivery-index').child($deliveryId).val() == $uid"
          }
        }
      }
    },

    "delivery-index": {
      ".read": true,
      ".write": "auth != null"
    },

    "rider-index": {
      ".read": true,
      ".write": "auth != null"
    },

    "riders": {
      "$riderId": {
        "location": {
          ".read": true,
          ".write": true
        }
      }
    },

    "rider-active": {
      "$riderId": {
        ".read": true,
        ".write": "auth != null"
      }
    },

    "deliveries-public": {
      "$deliveryId": {
        ".read": true,
        ".write": "auth != null",
        "status": {
          ".write": true
        }
      }
    },

    "feedback-queue": {
      "$deliveryId": {
        ".read": false,
        ".write": "newData.exists() && root.child('deliveries-public').child($deliveryId).exists()"
      }
    }
  }
}
